#. (itstool) path: section/p
#: C/basics.page:24
msgid ""
"Press <gui style=\"button\">New Game</gui> or press <keyseq><key>Ctrl</"
"key><key>N</key></keyseq> to open the grid size selection menu and press "
"<gui style=\"button\">3x3</gui>, <gui style=\"button\">4x4</gui>, or <gui "
"style=\"button\">5x5</gui> to start a new game with the selected grid size."
msgstr ""
"Nyomja meg az <gui style=\"button\">Új játék</gui> gombot vagy a "
"<keyseq><key>Ctrl</key><key>N</key></keyseq> billentyűkombinációt a "
"rácsméretválasztás menü megnyitásához, majd nyomja meg a <gui "
"style=\"button\">3x3</gui>, <gui style=\"button\">4x4</gui> vagy <gui "
"style=\"button\">5x5</gui> gombot a kiválasztott rácsmérettel történő új "
"játék indításához."

#. (itstool) path: section/p
#: C/basics.page:26
msgid ""
"Press <keyseq><key>Shift</key><key>Ctrl</key><key>N</key></keyseq> to start "
"a new game with the same grid size as the current game."
msgstr ""
"Nyomja meg a <keyseq><key>Shift</key><key>Ctrl</key><key>N</key></keyseq> "
"billentyűkombinációt a jelenlegi játék rácsméretével megegyező rácsméretű új "
"játék indításához."

